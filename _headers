# Cloudflare Pages — cache headers
# Les fichiers JS sont revalidés à chaque visite
# (évite que le navigateur serve d'anciennes versions depuis son cache)

/atelier/js/*
  Cache-Control: no-cache

/atelier/*.html
  Cache-Control: no-cache

/lis-tes-ratures/js/*
  Cache-Control: no-cache

/lis-tes-ratures/*.html
  Cache-Control: no-cache
